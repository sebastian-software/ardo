{
  "name": "ardo",
  "version": "4.1.0",
  "description": "React-first Static Documentation Framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./ui/styles.css": "./dist/ui/styles.css",
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./typedoc": {
      "types": "./dist/typedoc/index.d.ts",
      "import": "./dist/typedoc/index.js"
    },
    "./typedoc/components": {
      "types": "./dist/typedoc/components/index.d.ts",
      "import": "./dist/typedoc/components/index.js"
    },
    "./mdx-provider": {
      "types": "./dist/mdx/provider.d.ts",
      "import": "./dist/mdx/provider.js"
    },
    "./press.css": "./dist/ui/styles.css",
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./virtual": {
      "types": "./virtual.d.ts"
    }
  },
  "sideEffects": [
    "*.css",
    "*.css.ts",
    "*.css.js"
  ],
  "files": [
    "dist",
    "virtual.d.ts"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@mdx-js/rollup": "^3.1.1",
    "@resvg/resvg-js": "^2.6.2",
    "@shikijs/rehype": "^4.1.0",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/esbuild-plugin": "^2.3.22",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.2",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.2.0",
    "read-package-up": "^12.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.1.0",
    "typedoc": "^0.28.19",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@react-router/dev": "^8.0.0",
    "lucide-react": ">=0.400.0 <2.0.0",
    "mermaid": "^11.0.0",
    "react": ">=19.0.0 <20.0.0",
    "react-dom": ">=19.0.0 <20.0.0",
    "react-router": "^8.0.0",
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-router/dev": "^8.0.1",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/rollup-plugin": "^1.5.3",
    "estree-util-value-to-estree": "^3.5.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "unist-util-mdx-define": "^1.1.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "documentation",
    "static-site",
    "react",
    "react-router",
    "mdx",
    "typedoc",
    "markdown",
    "docs"
  ],
  "author": "Sebastian Software GmbH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastian-software/ardo.git",
    "directory": "packages/ardo"
  },
  "homepage": "https://ardo-docs.dev",
  "bugs": {
    "url": "https://github.com/sebastian-software/ardo/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/sebastian-software"
  }
}
