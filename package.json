{
  "name": "ardo-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "React-first Static Documentation Framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastian-software/ardo.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm --filter ardo dev",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest --run --config vitest.config.ts",
    "test:integration": "vitest --run --config vitest.integration.config.ts",
    "test:coverage": "vitest --run --coverage --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint": "eslint packages/*/src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "docs:dev": "pnpm -r --filter ./docs dev",
    "docs:build": "pnpm -r --filter './docs' build",
    "storybook": "storybook dev --port 6006",
    "storybook:build": "STORYBOOK_BASE=/storybook/ storybook build --output-dir storybook-static",
    "storybook:build:test": "storybook build --output-dir storybook-static",
    "storybook:serve": "http-server storybook-static -a 127.0.0.1 -p 6006 -s",
    "storybook:test": "test-storybook --url http://127.0.0.1:6006",
    "prepare": "husky"
  },
  "keywords": [
    "documentation",
    "static-site",
    "react",
    "react-router",
    "mdx",
    "typedoc",
    "markdown",
    "docs"
  ],
  "author": "Sebastian Software GmbH",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-setup": "^0.4.0",
    "husky": "^9.1.7",
    "http-server": "^14.1.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vercel": "^54.20.1",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "lint-staged": {
    "*.{ts,tsx,js,json,md,mdx,yml,yaml}": "prettier --write"
  }
}
